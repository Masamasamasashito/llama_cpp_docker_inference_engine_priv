# ==============================================================================
# 🚀 .env GET READY: HunyuanVideo 1.5 Setup (動画生成・人物特化)
# ==============================================================================
# HOW TO:
# 1. Copy this file to a new file named ".env"
#    Command: cp .env.example.hunyuanvideo-1.5 .env
#
# 2. ComfyUIにHunyuanVideo 1.5カスタムノードをインストール
#    cd ComfyUI/custom_nodes/
#    git clone https://github.com/Tencent/HunyuanVideo-ComfyUI.git
#    モデルファイルはComfyUI/models/配下に配置
#
# 3. Start ComfyUI
#    docker-compose -f docker-compose.comfyui.yml up -d
#
# Note: Generation takes 4-15 minutes per clip
# ==============================================================================

# ==============================================================================
# ⚙️ Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Global Settings
# ------------------------------------------------------------------------------
COMMON_TIMEZONE=Asia/Tokyo

# ------------------------------------------------------------------------------
# 2. Docker Image & Version (TAG)
# ------------------------------------------------------------------------------
COMMON_LDIE_DOCKER_COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui
COMMON_LDIE_DOCKER_COMFYUI_IMAGE_TAG=latest

# ------------------------------------------------------------------------------
# 3. Network Binding
# ------------------------------------------------------------------------------
DOCKER_HOST_BIND_ADDR=127.0.0.1

# 🔄 IF MULTI-ENV: Change this port (e.g., 8188 -> 18188)
DOCKER_HOST_PORT_COMFYUI=8188
COMFYUI_CONTAINER_LISTEN_PORT=8188  # It is not recommended to change this port

# ------------------------------------------------------------------------------
# 4. Model Settings
# ------------------------------------------------------------------------------
VIDEO_MODEL=hunyuan_video_1.5
VIDEO_MODEL_DESCRIPTION=HunyuanVideo 1.5 (Tencent, ~13B, ~16GB VRAM)
# VRAM: ~16GB | Speed: 4-15min/clip | Resolution: up to 720p
# Best for: human faces and portraits

# ------------------------------------------------------------------------------
# 5. Generation Parameters
# ------------------------------------------------------------------------------
VIDEO_WIDTH=720
VIDEO_HEIGHT=480
VIDEO_NUM_FRAMES=48
VIDEO_STEPS=30
VIDEO_CFG=7.5
