# Qwen3.5-27B 用環境変数
# モデルダウンロード:
#   curl -L -o models/Qwen3.5-27B-Q4_K_M.gguf https://huggingface.co/unsloth/Qwen3.5-27B-GGUF/resolve/main/Qwen3.5-27B-Q4_K_M.gguf
#   （約16.7GB）

LLAMA_MODEL_FILE=Qwen3.5-27B-Q4_K_M.gguf

# コンテキストサイズ
LLAMA_CTX_SIZE=8192

# 並列処理数
LLAMA_N_PARALLEL=2

# APIポート番号
LLAMA_PORT=8080

# GPU版のみ: GPUレイヤー数（27Bモデルは多めに設定）
LLAMA_N_GPU_LAYERS=99
