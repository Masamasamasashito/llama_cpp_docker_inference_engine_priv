# ==============================================================================
# 🚀 .env GET READY: Qwen3.5-9B Setup
# ==============================================================================
# HOW TO:
# 1. Copy this file to a new file named ".env"
#    Command: cp .env.example.qwen3.5-9b .env
#
# 2. Download the model file (約5.68GB)
#    curl -L -o models/Qwen3.5-9B-Q4_K_M.gguf https://huggingface.co/unsloth/Qwen3.5-9B-GGUF/resolve/main/Qwen3.5-9B-Q4_K_M.gguf
#
# 3. Generate security keys (Only needed for OpenClaw / LAN access)
#    Run the command below for your OS to append the API key to .env.
# ==============================================================================

# --- 🍎 macOS / 🐧 Linux (Copy & Paste into Terminal) ---
# echo "" >> .env
# echo "LLAMA_API_KEY=sk-local-$(openssl rand -hex 32)" >> .env

# --- 🪟 Windows PowerShell (Copy & Paste into PowerShell) ---
# "" | Add-Content .env
# $bytes = New-Object byte[] 32; (New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes($bytes); $hex = -join ($bytes | ForEach-Object { $_.ToString("x2") }); "LLAMA_API_KEY=sk-local-$hex" | Add-Content .env

# ==============================================================================
# 📦 ADVANCED: Running Multiple Local Environments
# ==============================================================================
# If you want to run a second instance alongside an existing one:
# 1. Create a separate directory for the new environment.
# 2. Change the HOST PORT in .env to avoid conflicts.
#    - DOCKER_HOST_PORT_LLAMA  (e.g., 8081 -> 18081)
#
# 3. RECOMMENDED: Keep DOCKER_HOST_BIND_ADDR on 127.0.0.1 (localhost)
#    Separate environments by port numbers only.
#
# 💡 TIP: Look for "# 🔄 IF MULTI-ENV:" comments below
#    to quickly identify all items that need to be changed.
# ==============================================================================

# ==============================================================================
# ⚙️ Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Global Settings
# ------------------------------------------------------------------------------
COMMON_TIMEZONE=Asia/Tokyo

# ------------------------------------------------------------------------------
# 2. Docker Image & Version (TAG)
# ------------------------------------------------------------------------------
# Pin versions for stability in production
# Basic functionality verified version `server-cuda`
COMMON_LDIE_DOCKER_LLAMA_GPU_IMAGE=ghcr.io/ggml-org/llama.cpp
COMMON_LDIE_DOCKER_LLAMA_GPU_IMAGE_TAG=server-cuda

# ------------------------------------------------------------------------------
# 3. Network Binding
# ------------------------------------------------------------------------------
# Default to 127.0.0.1 to avoid exposing ports publicly.
# For LAN access (e.g., OpenClaw on another PC), set to your private IP.
# Example: DOCKER_HOST_BIND_ADDR=192.168.1.100
DOCKER_HOST_BIND_ADDR=127.0.0.1

# 🔄 IF MULTI-ENV: Change this port (e.g., 8081 -> 18081)
DOCKER_HOST_PORT_LLAMA=8081
LLAMA_CONTAINER_LISTEN_PORT=8080  # It is not recommended to change this port

# ------------------------------------------------------------------------------
# 4. Model Settings
# ------------------------------------------------------------------------------
LLAMA_MODEL_FILE=Qwen3.5-9B-Q4_K_M.gguf

# ------------------------------------------------------------------------------
# 5. Inference Parameters
# ------------------------------------------------------------------------------
# OpenClaw 連携時は contextWindow が 16000 未満だと弾かれることがあるため 16384 推奨（VRAM 増・ローカル専用なら下げてよい）
LLAMA_CTX_SIZE=16384
LLAMA_N_PARALLEL=1
# GPU layers (9B model: all layers fit easily on GPU)
LLAMA_N_GPU_LAYERS=99

# ------------------------------------------------------------------------------
# 6. Security (API Key Authentication)
# ------------------------------------------------------------------------------
# [NOTE] If you ran the commands above, LLAMA_API_KEY is already at the bottom of this file.
# Uncomment below ONLY if you want to set a fixed manual key.
# LLAMA_API_KEY=sk-local-your-secret-key-here

# ------------------------------------------------------------------------------
# Generate security keys Command Results
# ------------------------------------------------------------------------------
