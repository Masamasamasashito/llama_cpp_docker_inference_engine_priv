# ==============================================================================
# 🚀 .env GET READY: LTX-Video Setup (動画生成・最速)
# ==============================================================================
# HOW TO:
# 1. Copy this file to a new file named ".env"
#    Command: cp .env.example.ltx-video .env
#
# 2. ComfyUIにLTX-Videoモデルとカスタムノードをインストール
#    ComfyUI Manager経由、またはHuggingFaceから手動ダウンロード
#
# 3. Start ComfyUI
#    docker-compose -f docker-compose.comfyui.yml up -d
# ==============================================================================

# ==============================================================================
# ⚙️ Configuration
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Global Settings
# ------------------------------------------------------------------------------
COMMON_TIMEZONE=Asia/Tokyo

# ------------------------------------------------------------------------------
# 2. Docker Image & Version (TAG)
# ------------------------------------------------------------------------------
COMMON_LDIE_DOCKER_COMFYUI_IMAGE=ghcr.io/ai-dock/comfyui
COMMON_LDIE_DOCKER_COMFYUI_IMAGE_TAG=latest

# ------------------------------------------------------------------------------
# 3. Network Binding
# ------------------------------------------------------------------------------
DOCKER_HOST_BIND_ADDR=127.0.0.1

# 🔄 IF MULTI-ENV: Change this port (e.g., 8188 -> 18188)
DOCKER_HOST_PORT_COMFYUI=8188
COMFYUI_CONTAINER_LISTEN_PORT=8188  # It is not recommended to change this port

# ------------------------------------------------------------------------------
# 4. Model Settings
# ------------------------------------------------------------------------------
VIDEO_MODEL=ltx-video
VIDEO_MODEL_DESCRIPTION=LTX-Video (Lightricks, ~2B, ~8GB VRAM)
# VRAM: ~8GB | Speed: 5sec video in ~4sec | Resolution: 512x512, 768x512

# ------------------------------------------------------------------------------
# 5. Generation Parameters
# ------------------------------------------------------------------------------
VIDEO_WIDTH=512
VIDEO_HEIGHT=512
VIDEO_NUM_FRAMES=24
VIDEO_STEPS=20
VIDEO_CFG=7.0
